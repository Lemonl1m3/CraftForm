# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd

.venv/
venv/
env/

.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

dist/
build/
*.egg-info/
*.eggs

# ==============================================================================
# Ruff
# ==============================================================================
.ruff_cache/

# ==============================================================================
# Terraform
# ==============================================================================
.terraform/

# State files contain sensitive infrastructure details — never commit
*.tfstate
*.tfstate.backup

# tfvars can contain secrets
*.tfvars
*.tfvars.json

# Local override files are for personal dev tweaks
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Saved plan output can embed sensitive values 
*.tfplan
tfplan

# Terraform crash logs
crash.log
crash.*.log

# Terraform CLI config
.terraformrc
terraform.rc

# ==============================================================================
# Lambda build artifacts
# ==============================================================================
*.zip
package/
lambda-build/   # the release workflow pip-installs deps into here before zipping

# ==============================================================================
# Secrets & credentials
# ==============================================================================
.env
.env.*
*.pem
*.key
secrets.yaml
secrets.json

# ==============================================================================
# Editors / IDEs
# ==============================================================================
# ignore personal vscode junk but keep the shared settings
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*~

# ==============================================================================
# OS
# ==============================================================================
.DS_Store
Thumbs.db
desktop.ini
