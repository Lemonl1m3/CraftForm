# ==============================================================================
# Terraform
# ==============================================================================
.terraform/

# State files contain sensitive infrastructure details — never commit
*.tfstate
*.tfstate.backup

# tfvars can contain secrets (API keys, passwords, etc.)
*.tfvars
*.tfvars.json

# Local override files are for personal dev tweaks, not shared
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform crash logs
crash.log
crash.*.log

# Terraform CLI config
.terraformrc
terraform.rc

# ==============================================================================
# Lambda build artifacts
# ==============================================================================
*.zip
package/

# ==============================================================================
# Secrets & credentials
# ==============================================================================
.env
.env.*
*.pem
*.key
secrets.yaml
secrets.json

# ==============================================================================
# OS
# ==============================================================================
.DS_Store
Thumbs.db
desktop.ini
